generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------- ENUMS ----------------
enum Role {
  student
  instructor
  admin
}

enum UserStatus {
  active
  blocked
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ---------------- USER ----------------
model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  password              String
  role                  Role                   @default(student)
  status                UserStatus             @default(active)
  avatar                String?
  enrolledCourses       Enrollment[]
  createdCourses        Course[]               @relation("InstructorCourses")
  reviews               Review[]
  payments              Payment[]
  assignmentSubmissions AssignmentSubmission[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  completedLessons      CompletedLesson[]

  @@map("users")
}

// ---------------- CATEGORY ----------------
model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ---------------- COURSE ----------------
model Course {
  id           String  @id @default(uuid())
  title        String
  description  String?
  thumbnail    String
  previewVideo String
  price        Float   @default(0)
  instructorId String
  isPublished  Boolean @default(false)
  instructor   User    @relation("InstructorCourses", fields: [instructorId], references: [id])

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  modules Module[]

  //IMPORTANT FIX
  enrolledUsers Enrollment[]
  payments      Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews   Review[]
  isDeleted Boolean  @default(false)

  @@index([categoryId])
  @@index([instructorId])
  @@map("courses")
}

// ---------------- MODULE ----------------
model Module {
  id          String       @id @default(uuid())
  title       String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  lessons     Lesson[]
  assignments Assignment[]
  order       Int          @default(0)
  isDeleted   Boolean      @default(false)

  @@map("modules")
}

// ---------------- REVIEW ----------------
model Review {
  id      String @id @default(uuid())
  content String
  rating  Int    @default(5)

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rating])
  @@index([courseId])
  @@index([userId])
  @@map("reviews")
}

// ---------------- LESSON ----------------
model Lesson {
  id               String            @id @default(uuid())
  title            String
  content          String?           @db.Text
  videoUrl         String
  duration         Float             @default(0)
  module           Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  order            Int               @default(0)
  completedByUsers CompletedLesson[]
  isDeleted        Boolean           @default(false)

  @@index([moduleId])
  @@map("lessons")
}

// ---------------- ASSIGNMENT ----------------
model Assignment {
  id          String                 @id @default(uuid())
  description String
  moduleId    String
  module      Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
  deadline    DateTime?
  isDeleted   Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([moduleId])
  @@map("assignments")
}

// ---------------- ENROLLMENT (🔥 MAIN FIX) ----------------
model Enrollment {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  enrolledAt   DateTime @default(now())
  lastActivity DateTime @updatedAt

  @@unique([userId, courseId]) // prevent duplicate enroll
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

// ---------------- COMPLETED LESSON ----------------
model CompletedLesson {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId String

  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("completed_lessons")
}

// ---------------- PAYMENT ----------------
model Payment {
  id              String        @id @default(uuid())
  amount          Float
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  stripeSessionId String?       @unique
  stripePaymentId String?       @unique

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  course   Course @relation(fields: [courseId], references: [id])
  courseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([courseId])
  @@map("payments")
}

// ---------------- ASSIGNMENT SUBMISSION ----------------
model AssignmentSubmission {
  id      String @id @default(uuid())
  content String // The text or link submitted
  status  String @default("submitted") // submitted, graded
  score   Float?

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  submittedAt DateTime @default(now())

  @@unique([userId, assignmentId])
  @@index([userId])
  @@index([assignmentId])
  @@map("assignment_submissions")
}

// ---------------- LIVE SESSION ----------------
model LiveSession {
  id            String   @id @default(uuid())
  title         String
  description   String?
  thumbnail     String?
  sessionDate   DateTime // When the session starts
  registrationDeadline DateTime // Registration cutoff time
  maxCapacity   Int?
  meetingLink   String?  // Only visible to registered users
  isPublished   Boolean  @default(false)
  registrations LiveRegistration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("live_sessions")
}

// ---------------- LIVE REGISTRATION ----------------
model LiveRegistration {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  
  session       LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String

  registeredAt  DateTime @default(now())

  @@unique([email, sessionId]) 
  @@map("live_registrations")
}
